# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor / backup
*.swp
*.swo
*~
*.bak.*
*.bak
.idea/
.vscode/

# Local / private overrides (never commit)
config/git/config.local
config/zsh/local.zsh
server-config/zsh/local.zsh

# Zsh runtime (generated when ZDOTDIR points into this repo)
config/zsh/.zcompdump*
config/zsh/.zsh_history
config/zsh/.zsh_sessions/
config/zsh/.zshrc.zwc
config/zsh/*.zwc
server-config/zsh/.zcompdump*
server-config/zsh/.zsh_history
server-config/zsh/.zsh_sessions/
server-config/zsh/*.zwc

# Tmux plugin manager (cloned on install)
config/tmux/plugins/

# Caches / logs
*.log
.cache/
**/node_modules/
