{
  "base_keymap": "VSCode",
  "vim_mode": true,
  "relative_line_numbers": "enabled",
  "cursor_shape": "bar",
  "cursor_blink": true,
  "tab_size": 2,
  "hard_tabs": false,
  "soft_wrap": "none",
  "ensure_final_newline_on_save": true,
  "show_whitespaces": "boundary",
  "indent_guides": {
    "enabled": true
  },
  "sticky_scroll": {
    "enabled": true
  },
  "minimap": {
    "show": "never"
  },
  "git": {
    "inline_blame": {
      "enabled": false
    }
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_size": 15,
  "ui_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark"
  },
  "terminal": {
    "font_family": "JetBrainsMono Nerd Font"
  }
}
