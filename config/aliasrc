# Clean JS project junk
nm_clean() {
  find . -name node_modules -type d -prune -print -exec rm -rf {} +
  echo "removed node_modules trees"
}
lock_clean() {
  rm -f package-lock.json yarn.lock pnpm-lock.yaml bun.lockb bun.lock
  echo "removed lockfiles"
}

