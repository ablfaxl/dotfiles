# @antfu/ni — auto-detect package manager (install via: make node)
# ni  = install   |  nr = run script  |  nlx = dlx/npx  |  nun = uninstall
# Fallbacks if ni is not on PATH yet:
if ! command -v ni >/dev/null 2>&1; then
  ni() {
    if [[ -f pnpm-lock.yaml ]] || [[ -f pnpm-workspace.yaml ]]; then pnpm install "$@"
    elif [[ -f yarn.lock ]]; then yarn install "$@"
    elif [[ -f bun.lockb ]] || [[ -f bun.lock ]]; then bun install "$@"
    else npm install "$@"; fi
  }
fi
if ! command -v nr >/dev/null 2>&1; then
  nr() {
    if [[ -f pnpm-lock.yaml ]] || [[ -f pnpm-workspace.yaml ]]; then pnpm run "$@"
    elif [[ -f yarn.lock ]]; then yarn run "$@"
    elif [[ -f bun.lockb ]] || [[ -f bun.lock ]]; then bun run "$@"
    else npm run "$@"; fi
  }
fi
if ! command -v nlx >/dev/null 2>&1; then
  nlx() {
    if command -v pnpm >/dev/null 2>&1; then pnpm dlx "$@"
    elif command -v bun >/dev/null 2>&1; then bunx "$@"
    else npx "$@"; fi
  }
fi
if ! command -v nun >/dev/null 2>&1; then
  nun() {
    if [[ -f pnpm-lock.yaml ]]; then pnpm remove "$@"
    elif [[ -f yarn.lock ]]; then yarn remove "$@"
    elif [[ -f bun.lockb ]] || [[ -f bun.lock ]]; then bun remove "$@"
    else npm uninstall "$@"; fi
  }
fi

