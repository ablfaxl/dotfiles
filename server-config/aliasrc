#!/usr/bin/env bash
# Server-focused aliases (Debian / Arch) — no GUI / desktop assumptions

edit() { "${EDITOR:-nvim}" "$@"; }

alias c='clear'
alias :q='exit'
alias cp='cp -i'
alias mv='mv -i'
alias df='df -h'
alias du='du -h'
alias free='free -h'
alias grep='grep --color=auto'
alias mkdir='mkdir -pv'
alias x='chmod +x'

alias ..='cd ..'
alias ...='cd ../..'

# Prefer modern tools when present
if command -v eza >/dev/null 2>&1; then
  alias ls='eza --group-directories-first --icons=auto'
  alias ll='eza -l --group-directories-first --icons=auto'
  alias la='eza -la --group-directories-first --icons=auto'
  alias tree='eza --tree'
elif command -v ls >/dev/null 2>&1; then
  alias ls='ls --color=auto'
  alias ll='ls -lah --color=auto'
  alias la='ls -lAh --color=auto'
fi

command -v bat >/dev/null 2>&1 && alias cat='bat --paging=never'
command -v batcat >/dev/null 2>&1 && ! command -v bat >/dev/null 2>&1 && alias cat='batcat --paging=never'
command -v nvim >/dev/null 2>&1 && alias vim='nvim'

alias path='echo -e ${PATH//:/\\n} | sort'
alias reload='source "${XDG_CONFIG_HOME:-$HOME/.config}/aliasrc"'

# Config shortcuts
alias zshrc='edit "${ZDOTDIR:-$HOME/.config/zsh}/.zshrc"'
alias zalias='edit "${XDG_CONFIG_HOME:-$HOME/.config}/aliasrc"'
alias envrc='edit "${XDG_CONFIG_HOME:-$HOME/.config}/env"'
alias tmuxrc='edit "${XDG_CONFIG_HOME:-$HOME/.config}/tmux/tmux.conf"'

# System / ops
alias ports='ss -tulpn 2>/dev/null || netstat -tulpn 2>/dev/null'
alias listening='ss -ltnp 2>/dev/null || true'
alias myip='curl -fsS https://ifconfig.me; echo'
alias j='journalctl -xe'
alias ju='journalctl --user -xe'
alias s='sudo systemctl'
alias sstatus='sudo systemctl status'
alias srestart='sudo systemctl restart'
alias senable='sudo systemctl enable --now'
alias sdisable='sudo systemctl disable --now'

# Process helpers
alias psg='ps aux | grep -v grep | grep'
killit() {
  ps aux | grep -v grep | grep "$@" | awk '{print $2}' | xargs -r kill
}

# Git essentials
alias gs='git status -s'
alias gl='git log --oneline --decorate -20'
alias gd='git diff'
alias ga='git add'
alias gc='git commit'
alias gp='git push'
alias pull='git pull'

# Docker / Lazydocker (https://lazydocker.com/)
alias d='docker'
alias dc='docker compose'
alias dps='docker ps -a'
alias ld='lazydocker'
alias lazyd='lazydocker'

mk() { mkdir -p "$1" && cd "$1" || return; }

# Archive extractor
ex() {
  if [ -f "$1" ]; then
    case "$1" in
      *.tar.bz2) tar xjf "$1" ;;
      *.tar.xz)  tar xf "$1" ;;
      *.tar.gz|*.tgz) tar xzf "$1" ;;
      *.bz2)     bunzip2 "$1" ;;
      *.gz)      gunzip "$1" ;;
      *.tar)     tar xf "$1" ;;
      *.zip)     unzip "$1" ;;
      *.7z)      7z x "$1" ;;
      *) echo "'$1' cannot be extracted via ex()" ;;
    esac
  else
    echo "'$1' is not a valid file"
  fi
}
