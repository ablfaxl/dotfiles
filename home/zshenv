# Loaded for every zsh (login + interactive + scripts).
# Bootstrap XDG / ZDOTDIR, then shared env (fnm, PATH, …) so non-login
# terminals (Alacritty default) still get node/pnpm/ni.
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"
export ZDOTDIR="${ZDOTDIR:-$XDG_CONFIG_HOME/zsh}"

# Shared PATH / fnm / bun / pnpm — safe to source in every zsh
if [ -f "${XDG_CONFIG_HOME}/env" ]; then
  # shellcheck disable=SC1091
  . "${XDG_CONFIG_HOME}/env"
fi
